{
  "name": "mediasnap",
  "version": "1.0.2",
  "description": "Single entry-point media downloader for TikTok, Instagram, YouTube, Reddit and more. Node.js / NestJS ready.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "lib/services"
  ],
  "scripts": {
    "build": "rimraf dist && tsc",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "sync-upstream": "bash scripts/sync-upstream.sh"
  },
  "keywords": [
    "downloader",
    "tiktok",
    "instagram",
    "youtube",
    "reddit",
    "nestjs",
    "media"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "metadownloader": "^1.0.0",
    "morgan": "^1.10.1",
    "qs": "^6.11.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
